{
  "compilerOptions": {
    "lib": ["es2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "./dist-scripts",
    "target": "es2020"
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules"]
}
